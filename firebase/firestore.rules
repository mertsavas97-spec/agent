rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Server-owned: quota, abuse, streak, subscription — client update forbidden
    function profileUpdateKeysOnly() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'displayName', 'examType', 'ageBand',
          'parentalConsentAt', 'consentAcceptedAt', 'onboardingCompletedAt',
          'updatedAt', 'deleteRequestedAt'
        ]);
    }

    function bootstrapDefaultsOk() {
      return request.resource.data.subscriptionStatus == 'free'
        && request.resource.data.dailySolveCount == 0
        && request.resource.data.invalidImageScore == 0
        && request.resource.data.streakCount == 0
        && request.resource.data.restrictedUntil == null
        && request.resource.data.examType in ['lgs', 'ygs', 'kpss'];
    }

    match /users/{uid} {
      allow read: if isOwner(uid);

      // Client bootstrap (IAM fallback): only with locked free-tier defaults
      allow create: if isOwner(uid)
        && bootstrapDefaultsOk()
        && request.resource.data.keys().hasOnly([
          'displayName', 'examType', 'ageBand', 'parentalConsentAt',
          'consentAcceptedAt', 'onboardingCompletedAt',
          'streakCount', 'streakLastActiveDate', 'dailySolveCount', 'dailySolveDate',
          'subscriptionStatus', 'invalidImageScore', 'restrictedUntil',
          'createdAt', 'updatedAt', 'deleteRequestedAt'
        ]);

      // Profile / exam / onboarding only — never quota or abuse fields
      allow update: if isOwner(uid)
        && profileUpdateKeysOnly()
        && request.resource.data.examType in ['lgs', 'ygs', 'kpss']
        && request.resource.data.subscriptionStatus == resource.data.subscriptionStatus
        && request.resource.data.dailySolveCount == resource.data.dailySolveCount
        && request.resource.data.dailySolveDate == resource.data.dailySolveDate
        && request.resource.data.invalidImageScore == resource.data.invalidImageScore
        && request.resource.data.restrictedUntil == resource.data.restrictedUntil
        && request.resource.data.streakCount == resource.data.streakCount;

      match /attempts/{attemptId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
      match /solutions/{solutionId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
      match /followUps/{followUpId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    match /topicStats/{uid}/topics/{topicId} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /solutionCache/{cacheKey} {
      allow read, write: if false;
    }

    // Server-only multi-instance rate limit buckets
    match /rateLimits/{limitId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
