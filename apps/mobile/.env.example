# Firebase Console → cozbil-dev-f9583 → Project settings → Your apps → Web
# API_KEY ve APP_ID'yi konsoldan yapıştır; diğerleri hazır.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=cozbil-dev-f9583.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=cozbil-dev-f9583
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=cozbil-dev-f9583.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=717206185063
EXPO_PUBLIC_FIREBASE_APP_ID=

# 0 = canlı Firebase · 1 = UI-only (auth/solve yok)
EXPO_PUBLIC_USE_EMULATORS=0
EXPO_PUBLIC_SCREENSHOT_MODE=0

# Optional dogfood OCR proxy when Cloud Functions invoker is blocked
# EXPO_PUBLIC_SOLVE_PROXY_URL=https://your-tunnel.example
# EXPO_PUBLIC_SOLVE_PROXY_TOKEN=rotating-development-token

# Premium UI dogfood (local entitlement). Prod release: leave unset.
# Pair with Functions COZBIL_BILLING_SANDBOX=1 for callable sandbox elevate.
# EXPO_PUBLIC_PREMIUM_SANDBOX=1

# Public HTTPS privacy page (host docs/legal/privacy-tr.html first)
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://your-domain/privacy
# EXPO_PUBLIC_SUPPORT_EMAIL=destek@cozbil.app
