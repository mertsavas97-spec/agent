  "explanationSteps": [
    {
      "title": "1. Adım",
      "body": "Sol tarafı aç: 2x - 6 + 5 = 2x - 1."
    },
    {
      "title": "2. Adım",
      "body": "Denklem: 2x - 1 = 3x - 1. Her iki tarafa +1 ekle: 2x = 3x."
    },
    {
      "title": "3. Adım",
      "body": "2x - 3x = 0 → -x = 0 → x = 0. Kontrol: sol 2(0-3)+5 = -1, sağ -1. Cevap A."
    }
