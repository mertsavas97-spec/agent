  "answerKey": "B",
  "explanationSteps": [
    {
      "title": "1. Ne kaldı?",
      "body": "Bütün 1. İlk yemeden sonra kalan: 1 − 3/8 = 5/8."
    },
    {
      "title": "2. Kalanın yarısı",
      "body": "Kalanın 1/2’si yenir: (5/8)×(1/2) = 5/16."
    },
    {
      "title": "3. Son durum",
      "body": "Kalan: 5/8 − 5/16 = 5/16. Cevap B."
    }
